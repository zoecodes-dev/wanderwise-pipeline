# WanderWise 환경 변수 예시
# 이 파일을 .env로 복사한 뒤 실제 키를 채우세요:  cp .env.example .env
# .env는 절대 커밋하지 마세요 (.gitignore로 차단되어 있음).

# --- 장소 수집 (pipeline/collect.py) ---
KAKAO_API_KEY=your-kakao-rest-api-key
# 리뷰수 필터·영업시간 검증에 사용. config의 enrich_with_google=true일 때만 필요(그 외 선택).
GOOGLE_API_KEY=your-google-places-api-key

# --- 묘사 생성 (pipeline/generate.py, api/itinerary.py) ---
ANTHROPIC_API_KEY=sk-ant-your-key

# --- 임베딩 (config의 embedding.provider에 맞는 키 하나만 있으면 됨) ---
# provider: openai 일 때
OPENAI_API_KEY=sk-your-openai-key
# provider: voyage 일 때
VOYAGE_API_KEY=your-voyage-key

# --- 적재 대상 DB (pipeline/load.py) ---
SUPABASE_URL=https://your-project.supabase.co
# service_role 키 — 매우 민감. 절대 공개/커밋 금지.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
